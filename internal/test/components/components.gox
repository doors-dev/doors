package components

import (
	"context"
	"time"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/doors/internal/test"
	"github.com/doors-dev/gox"
)

elem head(b doors.Source[test.Path]) {
	~>(doors.Inject(0, b)) <div hidden id="head-anchor">
		~(if ctx.Value(0).(test.Path).Vh {
			<title>home</title>
			<meta name="description" content="Welcome to the home page">
			<meta name="keywords" content="home, main, index">
			<meta property="og:title" content="Home Page">
		} else if ctx.Value(0).(test.Path).Vs {
			<title>s</title>
			<meta name="description" content="String page description">
			<meta name="category" content="text-content">
		} else {
			<title>~(ctx.Value(0).(test.Path).P)</title>
			<meta name="description" content=("Page for parameter: " + ctx.Value(0).(test.Path).P)>
			<meta name="keywords" content=("param, " + ctx.Value(0).(test.Path).P)>
			<meta property="og:title" content=("Param: " + ctx.Value(0).(test.Path).P)>
			<meta name="author" content="Parameter Author">
		})
	</div>
}

type LinksFragment struct {
	test.Beam
	Param string
}

elem (f *LinksFragment) Main() {
	~(head(f.B))
	<div hidden id="active-links">
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Active: doors.Active{
				Indicator: doors.IndicatorOnlyAttr("aria-current", "page"),
			},
		} <a id="active-default">active-default</a>
		~>doors.ALink{
			Model: test.Path{
				Vp: true,
				P: f.Param,
			},
			Active: doors.Active{
				PathMatcher: doors.PathMatcherStarts(),
				Indicator: doors.IndicatorOnlyAttr("data-active", "starts"),
			},
		} <a id="active-starts">active-starts</a>
		~>doors.ALink{
			Model: test.Path{
				Vp: true,
				P: f.Param,
			},
			Active: doors.Active{
				PathMatcher: doors.PathMatcherSegments(0),
				Indicator: doors.IndicatorOnlyAttr("data-active", "segments"),
			},
		} <a id="active-segments">active-segments</a>
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Fragment: "details",
			Active: doors.Active{
				QueryMatcher: doors.QueryMatcherOnlyIgnoreAll(),
				FragmentMatch: true,
				Indicator: doors.IndicatorOnlyAttr("data-active", "fragment"),
			},
		} <a id="active-fragment">active-fragment</a>
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Active: doors.Active{
				QueryMatcher: []doors.QueryMatcher{
					doors.QueryMatcherIgnoreSome("page"),
					doors.QueryMatcherSome("mode"),
					doors.QueryMatcherIfPresent("optional"),
				},
				Indicator: doors.IndicatorOnlyAttr("data-active", "query"),
			},
		} <a id="active-query">active-query</a>
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Active: doors.Active{
				QueryMatcher: doors.QueryMatcherOnlyIgnoreSome("page"),
				Indicator: doors.IndicatorOnlyAttr("data-active", "only-ignore-some"),
			},
		} <a id="active-query-only-ignore-some">active-query-only-ignore-some</a>
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Active: doors.Active{
				QueryMatcher: doors.QueryMatcherOnlySome("mode"),
				Indicator: doors.IndicatorOnlyAttr("data-active", "only-some"),
			},
		} <a id="active-query-only-some">active-query-only-some</a>
		~>doors.ALink{
			Model: test.Path{
				Vh: true,
			},
			Active: doors.Active{
				QueryMatcher: doors.QueryMatcherOnlyIfPresent("optional"),
				Indicator: doors.IndicatorOnlyAttr("data-active", "only-if-present"),
			},
		} <a id="active-query-only-if-present">active-query-only-if-present</a>
	</div>
	
	~>doors.ALink{
		Model: test.Path{
			Vh: true,
		},
	} <a id="home">home</a>
	
	~>doors.ALink{
		Model: test.Path{
			Vp: true,
			P: f.Param,
		},
	} <a id="param">param</a>
	
	~>doors.ALink{
		Model: test.Path{
			Vs: true,
			P: f.Param,
		},
	} <a id="string">string</a>
	<br>
	<br>
	<div id="action-target">action-target</div>
	~>doors.AClick{
		On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
			r.After(doors.ActionOnlyLocationRawAssign(test.Host + "/s"))
			return false
		},
	} <button id="raw-assign">raw-assign</button>
	~>doors.AClick{
		On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
			r.After(doors.ActionOnlyIndicate(
				doors.IndicatorOnlyAttrQuery("#action-target", "data-indicated", "true"),
				200 * time.Millisecond,
			))
			return false
		},
	} <button id="action-indicate">action-indicate</button>
	~>doors.AClick{
		On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
			r.After(doors.ActionOnlyScroll("#scroll-target"))
			return false
		},
	} <button id="action-scroll">action-scroll</button>
	~>doors.AClick{
		On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
			r.After(doors.ActionOnlyEmit("alert", "Hello!"))
			return false
		},
	} <button>
		alert
	</button>
	<script>
		$on("alert", (message) => {
			alert(message)
		})
	</script>
	<div style="height: 1800px"></div>
	<div id="scroll-target">scroll-target</div>
}

type ProxyFragment struct {
	test.NoBeam
	r *test.Reporter
}

type ProxyClassComponent struct {
	test.NoBeam
}

elem (ProxyClassComponent) Main() {
	<button id="proxy-class-component" class="base-component">proxy-class-component</button>
}

func proxyContainerClass() doors.Classes {
	return doors.Class("proxy-container", "proxy-skip").Filter("proxy-skip")
}

func classAttrValue() doors.Classes {
	return doors.Class("class-attr", "class-skip").Filter("class-skip").Add("class-added")
}

func classModifier() doors.Classes {
	return doors.Class("class-mod").Filter("class-skip")
}

func proxyDirectMod() gox.Modify {
	return gox.ModifyFunc(func(_ context.Context, tag string, attrs gox.Attrs) error {
		attrs.Get("data-proxy-mod").Set(tag + ":direct")
		return nil
	})
}

elem (f *ProxyFragment) Main() {
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			f.r.Update(ctx, 0, "literal")
			return false
		},
	} ~(<button id="proxy-literal">proxy-literal</button>)
	
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			f.r.Update(ctx, 0, "container")
			return false
		},
	} ~(<>
		<button id="proxy-container">proxy-container</button>
	</>)
	
	~>(doors.Class("proxy-literal")) ~(<button id="proxy-class-literal">proxy-class-literal</button>)
	
	~>(doors.ProxyMod(proxyDirectMod())) ~(<button id="proxy-direct-mod">proxy-direct-mod</button>)
	
	~>(proxyContainerClass()) ~(<>
		<button id="proxy-class-container">proxy-class-container</button>
		<button id="proxy-class-sibling">proxy-class-sibling</button>
	</>)
	
	~>(doors.Class("proxy-component")) ~ProxyClassComponent{}
	
	~>(doors.Class("proxy-parallel")) ~(<>
		~>(doors.Parallel()) <>
			<button id="proxy-class-parallel">proxy-class-parallel</button>
		</>
	</>)
	
	<div id="class-attr" class=(classAttrValue())>class-attr</div>
	<div id="class-mod" class="base-mod class-skip" (classModifier())>class-mod</div>
	
	~(f.r)
}
