package router

import (
	"context"
	"fmt"
	"time"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/gox"
)

type PathA struct {
	Path bool `path:"/a"`
}

elem pageA(b doors.Source[PathA]) {
	<html>
		<body>
			<div id="path">A</div>
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationAssign{Model: PathC{PathC1: true}})
					return false
				},
			} <button id="assign">assign</button>
		</body>
	</html>
}

type PathB struct {
	Path bool `path:"/b"`
}

type PathQuery struct {
	Path bool `path:"/q"`
	Tag *string `query:"tag"`
	Page *int `query:"page"`
}

type PathEscaped struct {
	Path bool `path:"/escaped/:Name"`
	Name string
}

type PathCrossA struct {
	Path bool `path:"/cross-a"`
}

type PathCrossB struct {
	Path bool `path:"/cross-b"`
}

type PathSlow struct {
	Path bool `path:"/slow"`
}

elem pageQuery(b doors.Source[PathQuery]) {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~>(doors.Inject(0, b)) <div id="tag">
				~(if ctx.Value(0).(PathQuery).Tag != nil {
					~(*ctx.Value(0).(PathQuery).Tag)
				})
			</div>
			~>(doors.Inject(0, b)) <div id="page-value">
				~(if ctx.Value(0).(PathQuery).Page != nil {
					~(fmt.Sprint(*ctx.Value(0).(PathQuery).Page))
				})
			</div>
			
			~{
				tag := "next"
				page := 2
			}
			~>doors.ALink{
				Model: PathQuery{
					Path: true,
					Tag: &tag,
					Page: &page,
				},
			} <a id="query-next">query-next</a>
		</body>
	</html>
}

elem pageLocation(b doors.Source[doors.Location]) {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~>(doors.Inject(0, b)) <div id="location-string">
				~(ctx.Value(0).(doors.Location).String())
			</div>
			~>(doors.Inject(0, b)) <div id="location-path">
				~(ctx.Value(0).(doors.Location).Path())
			</div>
			~>(doors.Inject(0, b)) <div id="tag-value">
				~(ctx.Value(0).(doors.Location).Query.Get("tag"))
			</div>
			~>(doors.Inject(0, b)) <div id="page-query-value">
				~(ctx.Value(0).(doors.Location).Query.Get("page"))
			</div>
		</body>
	</html>
}

elem pageEscaped(b doors.Source[PathEscaped]) {
	<html>
		<body>
			~>(doors.Inject(0, b)) <div id="name-value">
				~(ctx.Value(0).(PathEscaped).Name)
			</div>
			~{
				name := "next value/again"
			}
			~>doors.ALink{
				Model: PathEscaped{
					Path: true,
					Name: name,
				},
			} <a id="next-escaped">next-escaped</a>
		</body>
	</html>
}

elem pageCrossA() {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~>doors.ALink{
				Model: PathCrossB{
					Path: true,
				},
			} <a id="cross-next">cross-next</a>
		</body>
	</html>
}

elem pageCrossB() {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			<div id="page-name">cross-b</div>
		</body>
	</html>
}

elem pageSlow() {
	<html>
		<body>
			~(gox.EditorFunc(func(cur gox.Cursor) error {
				<-time.After(1100 * time.Millisecond)
				return nil
			}))
			<div id="slow-page">slow-page</div>
		</body>
	</html>
}

elem pageError(err error) {
	<html>
		~(doors.Status(500))
		<body>
			<div id="path">error</div>
			<div id="error-message">~(err.Error())</div>
		</body>
	</html>
}

elem static(path string, code int) {
	<html>
		<head></head>
		~(if code >= 0 {
			~(doors.Status(code))
		})
		<body>
			<div id="path">~(path)</div>
		</body>
	</html>
}

type PathC struct {
	PathC1 bool `path:"/c1"`
	PathC2 bool `path:"/c2"`
}

elem pageC(b doors.Source[PathC]) {
	<html>
		<body>
			~>(doors.Inject(0, b)) ~(if ctx.Value(0).(PathC).PathC1 {
				<div id="path">c1</div>
			} else {
				<div id="path">c2</div>
			})
			
			~>doors.ALink{
				Model: PathC{
					PathC1: true,
				},
			} <a>c1</a>
			
			~>doors.ALink{
				Model: PathC{
					PathC2: true,
				},
			} <a id="c2">c2</a>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationReplace{Model: PathC{PathC2: true}})
					return true
				},
			} <button id="replace">replace</button>
			<div id="marker">~(doors.IDRand())</div>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationReload{})
					return false
				},
			} <button id="reload">reload</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationAssign(PathB{}))
					return false
				},
			} <button id="assign_after">assign_after</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationReplace(PathB{}))
					return false
				},
			} <button id="replace_after">replace_after</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationReload())
					return false
				},
			} <button id="reload_after">reload_after</button>
		</body>
	</html>
}
