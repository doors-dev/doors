package router

import (
	"context"
	"fmt"
	"net/url"
	"time"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/gox"
)

type PathA struct {
	Path bool `path:"/a"`
}

elem pageA(b doors.Source[PathA]) {
	<html>
		<body>
			<div id="path">A</div>
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationAssign{Model: PathC{PathC1: true}})
					return false
				},
			} <button id="assign">assign</button>
		</body>
	</html>
}

type PathB struct {
	Path bool `path:"/b"`
}

type PathQuery struct {
	Path bool `path:"/q"`
	Tag *string `query:"tag"`
	Page *int `query:"page"`
}

type PathEscaped struct {
	Path bool `path:"/escaped/:Name"`
	Name string
}

type PathCrossA struct {
	Path bool `path:"/cross-a"`
}

type PathCrossB struct {
	Path bool `path:"/cross-b"`
}

type PathSlow struct {
	Path bool `path:"/slow"`
}

elem pageParallel() {
	<html>
		<body>
			~>(doors.Parallel()) <>
				~{
					<-time.After(500 * time.Millisecond)
				}
				<div id="part-a">part-a</div>
			</>
			~>(doors.Parallel()) <>
				~{
					<-time.After(500 * time.Millisecond)
				}
				<div id="part-b">part-b</div>
			</>
			<>
				~{
					<-time.After(500 * time.Millisecond)
				}
				<div id="part-c">part-c</div>
			</>
		</body>
	</html>
}

func values(items ...string) url.Values {
	v := url.Values{}
	for i := 0; i + 1 < len(items); i += 2 {
		v.Add(items[i], items[i + 1])
	}
	return v
}

elem pageQuery(b doors.Source[PathQuery]) {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~(b.Bind(elem(path PathQuery) {
				<div id="tag">
					~(if path.Tag != nil {
						~(*path.Tag)
					})
				</div>
				<div id="page-value">
					~(if path.Page != nil {
						~(fmt.Sprint(*path.Page))
					})
				</div>
			}))
			
			~{
				tag := "next"
				page := 2
			}
			~>doors.ALink{
				Model: PathQuery{
					Path: true,
					Tag: &tag,
					Page: &page,
				},
			} <a id="query-next">query-next</a>
		</body>
	</html>
}

elem pageLocation(b doors.Source[doors.Location]) {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~(b.Bind(elem(location doors.Location) {
				<div id="location-string">
					~(location.String())
				</div>
				<div id="location-path">
					~(location.Path())
				</div>
				<div id="tag-value">
					~(location.Query.Get("tag"))
				</div>
				<div id="page-query-value">
					~(location.Query.Get("page"))
				</div>
			}))
		</body>
	</html>
}

elem pageLocationActive(b doors.Source[doors.Location]) {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~(b.Bind(elem(location doors.Location) {
				<div id="location-string">
					~(location.String())
				</div>
			}))
			<div hidden id="active-links">
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
					},
					Active: doors.Active{
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-full">active-full</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active", "section"},
					},
					Active: doors.Active{
						PathMatcher: doors.PathMatcherStarts(),
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-starts">active-starts</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active", "section", "fixed"},
					},
					Active: doors.Active{
						PathMatcher: doors.PathMatcherSegments(0),
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-segments">active-segments</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
						),
					},
					Active: doors.Active{
						QueryMatcher: []doors.QueryMatcher{
							doors.QueryMatcherIgnoreAll(),
						},
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-ignore-all">active-ignore-all</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"optional", "yes",
							"page", "1",
						),
					},
					Active: doors.Active{
						QueryMatcher: []doors.QueryMatcher{
							doors.QueryMatcherIgnoreSome("page"),
							doors.QueryMatcherSome("mode"),
							doors.QueryMatcherIfPresent("optional"),
						},
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-query">active-query</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"optional", "yes",
							"page", "1",
						),
					},
					Active: doors.Active{
						QueryMatcher: doors.QueryMatcherOnlyIgnoreSome("page"),
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-only-ignore-some">active-only-ignore-some</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"page", "1",
						),
					},
					Active: doors.Active{
						QueryMatcher: doors.QueryMatcherOnlySome("mode"),
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-only-some">active-only-some</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"optional", "yes",
							"page", "1",
						),
					},
					Active: doors.Active{
						QueryMatcher: doors.QueryMatcherOnlyIfPresent("optional"),
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-only-if-present">active-only-if-present</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
					},
					Fragment: "details",
					Active: doors.Active{
						QueryMatcher: doors.QueryMatcherOnlyIgnoreAll(),
						FragmentMatch: true,
						Indicator: doors.IndicatorOnlyClass("active"),
					},
				} <a id="active-fragment">active-fragment</a>
			</div>
			<div id="nav-links">
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
					},
				} <a id="nav-home">nav-home</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active", "section", "child"},
					},
				} <a id="nav-starts">nav-starts</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active", "other"},
					},
				} <a id="nav-segments">nav-segments</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
					},
					Fragment: "details",
				} <a id="nav-fragment">nav-fragment</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"page", "9",
						),
					},
				} <a id="nav-query">nav-query</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"optional", "yes",
							"page", "9",
						),
					},
				} <a id="nav-query-optional">nav-query-optional</a>
				~>doors.ALink{
					Model: doors.Location{
						Segments: []string{"active"},
						Query: values(
							"mode", "view",
							"optional", "no",
							"page", "9",
						),
					},
				} <a id="nav-query-optional-miss">nav-query-optional-miss</a>
			</div>
		</body>
	</html>
}

elem pageEscaped(b doors.Source[PathEscaped]) {
	<html>
		<body>
			~(b.Bind(elem(path PathEscaped) {
				<div id="name-value">
					~(path.Name)
				</div>
			}))
			~{
				name := "next value/again"
			}
			~>doors.ALink{
				Model: PathEscaped{
					Path: true,
					Name: name,
				},
			} <a id="next-escaped">next-escaped</a>
		</body>
	</html>
}

elem pageCrossA() {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			~>doors.ALink{
				Model: PathCrossB{
					Path: true,
				},
			} <a id="cross-next">cross-next</a>
		</body>
	</html>
}

elem pageCrossB() {
	<html>
		<body>
			<div id="instance-id">~(doors.InstanceId(ctx))</div>
			<div id="page-name">cross-b</div>
		</body>
	</html>
}

elem pageSlow() {
	<html>
		<body>
			~(gox.EditorFunc(func(cur gox.Cursor) error {
				<-time.After(1100 * time.Millisecond)
				return nil
			}))
			<div id="slow-page">slow-page</div>
		</body>
	</html>
}

elem pageError(err error) {
	<html>
		~(doors.Status(500))
		<body>
			<div id="path">error</div>
			<div id="error-message">~(err.Error())</div>
		</body>
	</html>
}

elem static(path string, code int) {
	<html>
		<head></head>
		~(if code >= 0 {
			~(doors.Status(code))
		})
		<body>
			<div id="path">~(path)</div>
		</body>
	</html>
}

type PathC struct {
	PathC1 bool `path:"/c1"`
	PathC2 bool `path:"/c2"`
}

elem pageC(b doors.Source[PathC]) {
	<html>
		<body>
			~(b.Bind(elem(path PathC) {
				~(if path.PathC1 {
					<div id="path">c1</div>
				} else {
					<div id="path">c2</div>
				})
			}))
			
			~>doors.ALink{
				Model: PathC{
					PathC1: true,
				},
			} <a>c1</a>
			
			~>doors.ALink{
				Model: PathC{
					PathC2: true,
				},
			} <a id="c2">c2</a>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationReplace{Model: PathC{PathC2: true}})
					return true
				},
			} <button id="replace">replace</button>
			<div id="marker">~(doors.IDRand())</div>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					doors.Call(ctx, doors.ActionLocationReload{})
					return false
				},
			} <button id="reload">reload</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationAssign(PathB{}))
					return false
				},
			} <button id="assign_after">assign_after</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationReplace(PathB{}))
					return false
				},
			} <button id="replace_after">replace_after</button>
			
			~>doors.AClick{
				On: func(ctx context.Context, r doors.RequestEvent[doors.PointerEvent]) bool {
					r.After(doors.ActionOnlyLocationReload())
					return false
				},
			} <button id="reload_after">reload_after</button>
		</body>
	</html>
}
