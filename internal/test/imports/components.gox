package imports

import (
	"io/fs"
	"net/http"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/doors/internal/test"
	"github.com/doors-dev/gox"
)

elem staticFiles(_b doors.Source[test.Path]) {
	~(fileHref())
	~(fileSrc())
	~(fileRawSrc())
	~(fileHrefModify())
	~(fileRawHrefModify())
	~(fileSrcModify())
	~(fileRawSrcModify())
	~(fileCachedHref())
	~(fileCachedHrefModify())
	~(filePrivateHref())
	~(filePrivateHrefModify())
	~(framePrivateSrc())
}

elem fileHref() {
	<link rel="stylesheet" href=(doors.ResourceLocalFS(modulePath + "/style.css"))/>
}

elem fileRawHref() {
	<link rel="stylesheet" href=(func(w http.ResponseWriter, r *http.Request) {
		w.Write(styleRawBytes)
	})/>
}

elem fileSrc() {
	<script src=(doors.ResourceLocalFS(modulePath + "/index.js"))></script>
}

elem fileRawSrc() {
	<script src=(func(w http.ResponseWriter, r *http.Request) {
		w.Write(moduleBytes)
	})></script>
}

elem fileHrefModify() {
	<link rel="stylesheet" (doors.ResourceLocalFS(modulePath + "/style.css"))/>
}

elem fileRawHrefModify() {
	<link rel="stylesheet" (doors.ResourceHandler(func(w http.ResponseWriter, r *http.Request) {
		w.Write(styleRawBytes)
	}))/>
}

elem fileSrcModify() {
	<script (doors.ResourceLocalFS(modulePath + "/index.js"))></script>
}

elem fileRawSrcModify() {
	<script (doors.ResourceHandler(func(w http.ResponseWriter, r *http.Request) {
		w.Write(moduleBytes)
	}))></script>
}

elem fileCachedHref() {
	<a
		id="cached-href"
		href=(doors.ResourceBytes([]byte("hello")))
		cache
		name="hello.txt">
		Download
	</a>
}

elem fileCachedHrefModify() {
	<a
		id="cached-href-modify"
		(doors.ResourceBytes([]byte("hello")))
		cache
		name="hello-modify.txt">
		Download
	</a>
}

elem filePrivateHref() {
	<a
		id="private-href"
		href=(doors.ResourceBytes([]byte("hello")))
		name="private.txt">
		Download
	</a>
}

elem filePrivateHrefModify() {
	<a
		id="private-href-modify"
		(doors.ResourceBytes([]byte("hello")))
		name="private-modify.txt">
		Download
	</a>
}

elem framePrivateSrc() {
	<iframe
		id="private-frame"
		src=(doors.ResourceString(`<html><body>frame</body></html>`))
		name="frame.html"></iframe>
}

elem fileCachedHrefBad(_b doors.Source[test.Path]) {
	<a
		href=(doors.ResourceHandler(func(w http.ResponseWriter, r *http.Request) {
			w.Write([]byte("hello"))
		}))
		cache>
		Download
	</a>
}

elem styleBytesHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceBytes(styleRawBytes))/>
}

elem styleInlineHead(_b doors.Source[test.Path]) {
	<style>
		h1 {
			color: red;
		}
	</style>
}

elem styleRawHead(_b doors.Source[test.Path]) {
	<style output="raw">
		h1 {
			color: red;
		}
	</style>
}

elem styleMinifyHead(_b doors.Source[test.Path]) {
	<style output="minify">
		h1 {
			color: red;
		}
	</style>
}

elem styleBytesShortHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(styleRawBytes)/>
}

elem styleBytesModifyHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" (doors.ResourceBytes(styleRawBytes))/>
}

elem styleStringHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceString(string(styleRawBytes)))/>
}

elem styleExternalHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceExternal(test.Host + "/module/style.css"))/>
}

elem styleProxyHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceProxy(test.Host + "/module/style.css"))/>
}

elem styleHostedHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=("/module/style.css")/>
}

elem styleHostedRawHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=("/module/style.css") output="raw"/>
}

elem styleHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceLocalFS(modulePath + "/style.css"))/>
}

elem styleFSHead(_b doors.Source[test.Path]) {
	~{
		moduleDir, _ := fs.Sub(moduleFS, "module_src")
	}
	<link rel="stylesheet" href=(doors.ResourceFS(moduleDir, "style.css"))/>
}

elem styleNamedHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceBytes(styleRawBytes)) name="named.css"/>
}

elem stylePrivateNamedHead(_b doors.Source[test.Path]) {
	<link rel="stylesheet" href=(doors.ResourceBytes(styleRawBytes)) private name="private.css"/>
}

elem stylePrivateHead(_b doors.Source[test.Path]) {
	<style private name="private-inline">
		h1 {
			color: red;
		}
	</style>
}

elem stylePrivateNamedExtHead(_b doors.Source[test.Path]) {
	<style private name="private-inline.css">
		h1 {
			color: red;
		}
	</style>
}

elem styleNoCacheHead(_b doors.Source[test.Path]) {
	<style nocache name="nocache-inline">
		h1 {
			color: red;
		}
	</style>
}

elem moduleExternalHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceExternal(test.Host + "/module/index.js"))
		type="module"
		specifier="module"></script>
}

elem moduleBundleHostHead(_b doors.Source[test.Path]) {
	<script
		src=("/module/index.js")
		type="module"
		specifier="module"></script>
}

elem moduleBundleFSHead(_b doors.Source[test.Path]) {
	~{
		moduleBundleDir, _ := fs.Sub(moduleBundleFS, "module_bundle_src")
	}
	<script
		src=(doors.ResourceFS(moduleBundleDir, "index.ts"))
		type="module"
		output="bundle"
		specifier="module"></script>
}

elem moduleRawBytesHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceBytes(moduleRawBytes))
		type="module"
		output="raw"
		specifier="module"></script>
}

elem moduleRawBytesShortHead(_b doors.Source[test.Path]) {
	<script
		src=(moduleRawBytes)
		type="module"
		output="raw"
		specifier="module"></script>
}

elem moduleRawBytesModifyHead(_b doors.Source[test.Path]) {
	<script
		(doors.ResourceBytes(moduleRawBytes))
		type="module"
		output="raw"
		specifier="module"></script>
}

elem modulePreloadBytesHead(_b doors.Source[test.Path]) {
	<link
		rel="modulepreload"
		href=(doors.ResourceBytes(moduleRawBytes))
		specifier="module"/>
}

elem moduleRawHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceLocalFS(modulePath + "/index.js"))
		type="module"
		output="raw"
		specifier="module"></script>
}

elem moduleBytesHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceBytes(moduleRawBytes))
		type="module"
		specifier="module"></script>
}

elem moduleStringHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceString(string(moduleRawBytes)))
		type="module"
		specifier="module"></script>
}

elem moduleProxyHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceProxy(test.Host + "/module/index.js"))
		type="module"
		specifier="module"></script>
}

elem moduleHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceLocalFS(modulePath + "/index.ts"))
		name="module.js"
		type="module"
		specifier="module"></script>
}

elem moduleVisibleHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceLocalFS(modulePath + "/index.ts"))
		id="module-tag"
		type="module"
		specifier="module"></script>
}

elem modulePreloadNamedHead(_b doors.Source[test.Path]) {
	<link
		rel="modulepreload"
		href=(doors.ResourceBytes(moduleRawBytes))
		name="module-preload.js"
		specifier="module"/>
}

elem scriptInlineHead(_b doors.Source[test.Path]) {
	<script>
		window.__importsValue = "hello"
	</script>
}

elem scriptInlineNamedExtHead(_b doors.Source[test.Path]) {
	<script id="script-inline-ext" name="inline-script.js">
		window.__importsValue = "hello"
	</script>
}

elem scriptInlineBytesHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceBytes([]byte(`window.__importsValue = "hello"`)))
		output="inline"></script>
}

elem scriptStringHead(_b doors.Source[test.Path]) {
	<script src=(doors.ResourceString(`window.__importsValue = "hello"`))></script>
}

elem scriptPrivateHead(_b doors.Source[test.Path]) {
	<script
		id="script-private"
		src=(doors.ResourceString(`window.__importsValue = "hello"`))
		private
		name="private-script.js"></script>
}

elem scriptNoCacheHead(_b doors.Source[test.Path]) {
	<script
		id="script-nocache"
		src=(doors.ResourceString(`window.__importsValue = "hello"`))
		nocache
		name="nocache-script.js"></script>
}

elem reactHead(_b doors.Source[test.Path]) {
	<script
		src=(doors.ResourceLocalFS(preactPath + "/index.tsx"))
		type="module"
		output="bundle"
		specifier="preact"></script>
	<script
		src=(doors.ResourceLocalFS(reactPath + "/index.tsx"))
		type="module"
		output="bundle"
		specifier="react"></script>
}

type ModuleFragment struct {
	test.NoBeam
}

elem (f *ModuleFragment) Main() {
	<div id="report-0"></div>
	<script>
		const module = await import("module")
		document.getElementById("report-0").innerHTML = module.test()
	</script>
}

type ReactFragment struct {
	test.NoBeam
}

elem (f *ReactFragment) Main() {
	<div id="preact"></div>
	<script>
		const app = await import("preact")
		app.init(document.getElementById("preact"))
	</script>
	<div id="react"></div>
	<script>
		const app = await import("react")
		app.init(document.getElementById("react"))
	</script>
}

type ValueFragment struct {
	test.NoBeam
}

elem (f *ValueFragment) Main() {
	<div id="report-0"></div>
	<script>
		document.getElementById("report-0").innerHTML = window.__importsValue
	</script>
}

type Empty struct {
	test.NoBeam
}

elem (f *Empty) Main() {}
