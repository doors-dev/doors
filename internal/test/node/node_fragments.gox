package door

import (
	"context"
	"errors"
	"fmt"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/doors/internal/test"
	"github.com/doors-dev/gox"
)

type FragmentMany struct {
	n doors.Door
	test.NoBeam
}

elem (f *FragmentMany) sample() {
	<div class="sample">sample</div>
}

elem (f *FragmentMany) manyDoors() {
	~(for i := range 20 {
		<span style="display:none">~(fmt.Sprint(i))</span>
		~(&f.n)
	})
}

elem (f *FragmentMany) replaced() {
	~{
		f.n.Static(ctx, f.sample())
	}
	~(for i := range 100 {
		<span style="display:none">~(fmt.Sprint(i))</span>
		~(&f.n)
	})
}

elem (f *FragmentMany) Main() {
	~{
		f.n.Inner(ctx, f.sample())
		n := doors.Door{}
	}
	~>(n) <>
		~(f.manyDoors())
	</>
	~(test.Button("replace", func(ctx context.Context) bool {
		n.Inner(ctx, f.replaced())
		return true
	}))
}

type FragmentProxyWrappedSiblings struct {
	n doors.Door
	test.NoBeam
}

elem (f *FragmentProxyWrappedSiblings) Main() {
	~(gox.EditorFunc(func(cur gox.Cursor) error {
		return f.n.Proxy(cur, gox.Elem(func(cur gox.Cursor) error {
			if err := cur.Init("div"); err != nil {
				return err
			}
			if err := cur.Set("id", "proxy-wrap-first"); err != nil {
				return err
			}
			if err := cur.Submit(); err != nil {
				return err
			}
			if err := cur.Text("first"); err != nil {
				return err
			}
			if err := cur.Close(); err != nil {
				return err
			}
			
			if err := cur.Init("div"); err != nil {
				return err
			}
			if err := cur.Set("id", "proxy-wrap-second"); err != nil {
				return err
			}
			if err := cur.Submit(); err != nil {
				return err
			}
			if err := cur.Text("second"); err != nil {
				return err
			}
			return cur.Close()
		}))
	}))
}

type FragmentProxyWrappedLoop struct {
	n doors.Door
	test.NoBeam
}

elem (f *FragmentProxyWrappedLoop) Main() {
	~>(f.n) ~(for i := range 2 {
		<div id=(fmt.Sprintf("proxy-loop-%d", i))>~(fmt.Sprint(i))</div>
	})
}

type FragmentX struct {
	report doors.Door
	n doors.Door
	test.NoBeam
}

func (f *FragmentX) rep(ctx context.Context, s string) {
	f.report.Inner(ctx, test.Report(s))
}

elem (f *FragmentX) Main() {
	~>(f.n) <>
		~(test.Marker("init"))
	</>
	~>(f.report) ~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			ch := f.n.XInner(ctx, test.Marker("updated"))
			err, ok := <-ch
			if !ok {
				f.rep(ctx, "channel closed")
				return false
			}
			if err != nil {
				f.rep(ctx, "channel err: " + err.Error())
				return false
			}
			f.rep(ctx, "ok upd")
			return false
		},
	} <button id="updatex">C</button>
	
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			ch := f.n.XStatic(ctx, nil)
			err, ok := <-ch
			if !ok {
				f.rep(ctx, "channel closed")
				return false
			}
			if err != nil {
				f.rep(ctx, "channel err: " + err.Error())
				return false
			}
			f.rep(ctx, "ok del")
			return false
		},
	} <button id="removex">R</button>
}

type FragmentXDoor struct {
	report doors.Door
	frame doors.Door
	n doors.Door
	test.NoBeam
}

func (f *FragmentXDoor) rep(ctx context.Context, s string) {
	f.report.Inner(ctx, test.Report(s))
}

func (f *FragmentXDoor) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: " + err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentXDoor) mount() {
	~(&f.n)
}

elem (f *FragmentXDoor) Main() {
	~{
		f.n.Inner(ctx, test.Marker("x-init"))
		f.frame.Inner(ctx, f.mount())
	}
	~(&f.frame)
	~(&f.report)
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XReload(ctx), "ok reload")
		},
	} <button id="xreload">xreload</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XOuter(ctx, <section id="x-rebased-root">
				~(test.Marker("x-rebased"))
			</section>), "ok rebase")
		},
	} <button id="xrebase">xrebase</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XInner(ctx, nil), "ok clear")
		},
	} <button id="xclear">xclear</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XInner(ctx, test.Marker("x-updated")), "ok update")
		},
	} <button id="xupdate">xupdate</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XUnmount(ctx), "ok unmount")
		},
	} <button id="xunmount">xunmount</button>
	~(test.Button("xremount", func(ctx context.Context) bool {
		f.frame.Inner(ctx, f.mount())
		return false
	}))
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XStatic(ctx, test.Marker("x-replaced")), "ok replace")
		},
	} <button id="xreplace">xreplace</button>
}

type EmbeddedFragment struct {
	n1 doors.Door
	n2 doors.Door
	n3 doors.Door
	test.NoBeam
}

elem (f *EmbeddedFragment) Main() {
	~>(f.n1) <>
		~>(f.n2) <div>
			~(test.Marker("init"))
		</div>
		~(test.Marker("static"))
	</>
	~(&f.n3)
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Static(ctx, nil)
				return true
			},
		})>
		C
	</button>
	<button
		id="clear"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n1.Inner(ctx, nil)
				return true
			},
		})>
		C
	</button>
	<button
		id="replace"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Inner(ctx, test.Marker("replaced"))
				f.n3.Inner(ctx, test.Marker("temp"))
				f.n3.Static(ctx, &f.n2)
				return true
			},
		})>
		C
	</button>
}

type DynamicFragment struct {
	n1 doors.Door
	n2 doors.Door
	test.NoBeam
}

elem (f *DynamicFragment) Main() {
	~{
		f.n1.Inner(ctx, test.Marker("init"))
	}
	
	~>(f.n1) <div/>
	
	<button
		id="update"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n1.Inner(ctx, test.Marker("updated"))
				return true
			},
		})>
		U
	</button>
	<button
		id="replace"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Inner(ctx, test.Marker("replaced"))
				f.n1.Static(ctx, &f.n2)
				return true
			},
		})>
		Rp
	</button>
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Static(ctx, nil)
				return true
			},
		})>
		Remove
	</button>
}

type BeforeFragment struct {
	doorInit doors.Door
	doorUpdate doors.Door
	doorRemoved doors.Door
	doorReplaced doors.Door
	test.NoBeam
}

elem (f *BeforeFragment) Main() {
	~>(f.doorInit) <div>
		~(test.Marker("init"))
	</div>
	
	~{
		f.doorUpdate.Inner(ctx, test.Marker("updated"))
	}
	~>(f.doorUpdate) <div>
	</div>
	
	~{
		f.doorRemoved.Inner(ctx, test.Marker("removed"))
	}
	~{
		f.doorRemoved.Static(ctx, nil)
	}
	~(&f.doorRemoved)
	
	~{
		f.doorReplaced.Static(ctx, test.Marker("replaced"))
	}
	
	~>(f.doorReplaced) <div>
		~(test.Marker("initReplaced"))
	</div>
}

type LifeCycleFragment struct {
	frame doors.Door
	node doors.Door
	test.NoBeam
}

elem (f *LifeCycleFragment) Main() {
	~>(f.frame) ~(f.initial())
	<button
		id="reload"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Reload(ctx)
				return false
			},
		})>
		Reload
	</button>
	<button
		id="updateEmpty"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Inner(ctx, f.newEmpty())
				return false
			},
		})>
		Update1
	</button>
	<button
		id="updateEmptyAlt"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Inner(ctx, f.newEmptyAlt())
				return false
			},
		})>
		Update1Alt
	</button>
	<button
		id="updateContent"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Inner(ctx, f.newContent())
				return false
			},
		})>
		Update2
	</button>
	<button
		id="updateInner"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Inner(ctx, test.Marker("inner-maintained"))
				return false
			},
		})>
		UpdateInner
	</button>
	<button
		id="updateOuter"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Outer(ctx, f.newOuter())
				return false
			},
		})>
		UpdateOuter
	</button>
	<button
		id="replaceStatic"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Static(ctx, test.Marker("static-presist"))
				return false
			},
		})>
		ReplaceStatic
	</button>
	<button
		id="updateEditor"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Inner(ctx, f.newEditor())
				return false
			},
		})>
		Update2
	</button>
	<button
		id="clear"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Inner(ctx, nil)
				return false
			},
		})>
		Clear
	</button>
	<button
		id="unmount"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Unmount(ctx)
				return false
			},
		})>
		Unmount
	</button>
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Static(ctx, nil)
				return false
			},
		})>
		Remove
	</button>
}

elem (f *LifeCycleFragment) initial() {
	<div>
		~>(f.node) <div>
			~(test.Marker("presist"))
		</div>
	</div>
}
elem (f *LifeCycleFragment) newEmpty() {
	<div>
		~>(f.node) <div id="new">
		</div>
	</div>
}

elem (f *LifeCycleFragment) newEmptyAlt() {
	<div>
		~>(f.node) <section id="new-alt">
		</section>
	</div>
}

elem (f *LifeCycleFragment) newContent() {
	<div>
		~>(f.node) <div id="new2">
			~(test.Marker("presist2"))
		</div>
	</div>
}

elem (f *LifeCycleFragment) newOuter() {
	<section id="outer-root">
		~(test.Marker("outer-presist"))
	</section>
}

elem (f *LifeCycleFragment) newEditor() {
	<div>
		~(&f.node)
	</div>
}

type FragmentProxyReloadContent struct {
