func (f *FragmentHierarchy) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: " + err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentHierarchy) childBody() {
