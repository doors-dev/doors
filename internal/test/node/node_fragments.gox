	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XReload(ctx), "ok reload")
		},
	} <button id="reload-after-unmount">reload-after-unmount</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XOuter(ctx, f.rebased()), "ok rebase")
		},
	} <button id="rebase-after-unmount">rebase-after-unmount</button>
	~(test.Button("remount-after-rebase", func(ctx context.Context) bool {
		f.frame.Inner(ctx, f.mount())
		return false
	}))
}

type FragmentProxyMove struct {
	report doors.Door
	frame1 doors.Door
	frame2 doors.Door
	node doors.Door
	test.NoBeam
}

func (f *FragmentProxyMove) rep(ctx context.Context, s string) {
	f.report.Inner(ctx, test.Report(s))
}

func (f *FragmentProxyMove) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: " + err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentProxyMove) mountFrame1() {
	<section id="frame1">
		~(&f.node)
	</section>
}

elem (f *FragmentProxyMove) mountFrame2() {
	<section id="frame2">
		~(&f.node)
	</section>
}

elem (f *FragmentProxyMove) frame2Empty() {
	<section id="frame2"></section>
}

elem (f *FragmentProxyMove) rebased() {
	<section id="proxy-moved-root">
		~(test.Marker("proxy-moved"))
	</section>
}

elem (f *FragmentProxyMove) Main() {
	~{
		f.node.Inner(ctx, test.Marker("proxy-base"))
		f.frame1.Inner(ctx, f.mountFrame1())
		f.frame2.Inner(ctx, f.frame2Empty())
	}
	~(&f.frame1)
	~(&f.frame2)
	~(&f.report)
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XOuter(ctx, f.rebased()), "ok rebase")
		},
	} <button id="rebase-proxy-move">rebase-proxy-move</button>
	~(test.Button("move-proxy", func(ctx context.Context) bool {
		f.frame2.Inner(ctx, f.mountFrame2())
		return false
	}))
}

