package door

import (
	"context"
	"errors"
	"fmt"
	
	"github.com/doors-dev/doors"
	"github.com/doors-dev/doors/internal/test"
	"github.com/doors-dev/gox"
)

type FragmentMany struct {
	n doors.Door
	test.NoBeam
}

elem (f *FragmentMany) sample() {
	<div class="sample">sample</div>
}

elem (f *FragmentMany) manyDoors() {
	~(for i := range 20 {
		<span style="display:none">~(fmt.Sprint(i))</span>
		~(&f.n)
	})
}

elem (f *FragmentMany) replaced() {
	~{
		f.n.Replace(ctx, f.sample())
	}
	~(for i := range 100 {
		<span style="display:none">~(fmt.Sprint(i))</span>
		~(&f.n)
	})
}

elem (f *FragmentMany) Main() {
	~{
		f.n.Update(ctx, f.sample())
		n := doors.Door{}
	}
	~>(n) <>
		~(f.manyDoors())
	</>
	~(test.Button("replace", func(ctx context.Context) bool {
		n.Update(ctx, f.replaced())
		return true
	}))
}

type FragmentX struct {
	report doors.Door
	n doors.Door
	test.NoBeam
}

func (f *FragmentX) rep(ctx context.Context, s string) {
	f.report.Update(ctx, test.Report(s))
}

elem (f *FragmentX) Main() {
	~>(f.n) <>
		~(test.Marker("init"))
	</>
	~>(f.report) ~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			ch := f.n.XUpdate(ctx, test.Marker("updated"))
			err, ok := <-ch
			if !ok {
				f.rep(ctx, "channel closed")
				return false
			}
			if err != nil {
				f.rep(ctx, "channel err: " + err.Error())
				return false
			}
			f.rep(ctx, "ok upd")
			return false
		},
	} <button id="updatex">C</button>
	
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			ch := f.n.XDelete(ctx)
			err, ok := <-ch
			if !ok {
				f.rep(ctx, "channel closed")
				return false
			}
			if err != nil {
				f.rep(ctx, "channel err: " + err.Error())
				return false
			}
			f.rep(ctx, "ok del")
			return false
		},
	} <button id="removex">R</button>
}

type FragmentXDoor struct {
	report doors.Door
	frame doors.Door
	n doors.Door
	test.NoBeam
}

func (f *FragmentXDoor) rep(ctx context.Context, s string) {
	f.report.Update(ctx, test.Report(s))
}

func (f *FragmentXDoor) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: "+err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentXDoor) mount() {
	~(&f.n)
}

elem (f *FragmentXDoor) Main() {
	~{
		f.n.Update(ctx, test.Marker("x-init"))
		f.frame.Update(ctx, f.mount())
	}
	~(&f.frame)
	~(&f.report)
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XReload(ctx), "ok reload")
		},
	} <button id="xreload">xreload</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XRebase(ctx, <section id="x-rebased-root">
				~(test.Marker("x-rebased"))
			</section>), "ok rebase")
		},
	} <button id="xrebase">xrebase</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XClear(ctx), "ok clear")
		},
	} <button id="xclear">xclear</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XUpdate(ctx, test.Marker("x-updated")), "ok update")
		},
	} <button id="xupdate">xupdate</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XUnmount(ctx), "ok unmount")
		},
	} <button id="xunmount">xunmount</button>
	~(test.Button("xremount", func(ctx context.Context) bool {
		f.frame.Update(ctx, f.mount())
		return false
	}))
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.n.XReplace(ctx, test.Marker("x-replaced")), "ok replace")
		},
	} <button id="xreplace">xreplace</button>
}

type EmbeddedFragment struct {
	n1 doors.Door
	n2 doors.Door
	n3 doors.Door
	test.NoBeam
}

elem (f *EmbeddedFragment) Main() {
	~>(f.n1) <>
		~>(f.n2) <div>
			~(test.Marker("init"))
		</div>
		~(test.Marker("static"))
	</>
	~(&f.n3)
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Delete(ctx)
				return true
			},
		})>
		C
	</button>
	<button
		id="clear"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n1.Clear(ctx)
				return true
			},
		})>
		C
	</button>
	<button
		id="replace"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Update(ctx, test.Marker("replaced"))
				f.n3.Update(ctx, test.Marker("temp"))
				f.n3.Replace(ctx, &f.n2)
				return true
			},
		})>
		C
	</button>
}

type DynamicFragment struct {
	n1 doors.Door
	n2 doors.Door
	test.NoBeam
}

elem (f *DynamicFragment) Main() {
	~{
		f.n1.Update(ctx, test.Marker("init"))
	}
	
	~>(f.n1) <div/>
	
	<button
		id="update"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n1.Update(ctx, test.Marker("updated"))
				return true
			},
		})>
		U
	</button>
	<button
		id="replace"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Update(ctx, test.Marker("replaced"))
				f.n1.Replace(ctx, &f.n2)
				return true
			},
		})>
		Rp
	</button>
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.n2.Delete(ctx)
				return true
			},
		})>
		Remove
	</button>
}

type BeforeFragment struct {
	doorInit doors.Door
	doorUpdate doors.Door
	doorRemoved doors.Door
	doorReplaced doors.Door
	test.NoBeam
}

elem (f *BeforeFragment) Main() {
	~>(f.doorInit) <div>
		~(test.Marker("init"))
	</div>
	
	~{
		f.doorUpdate.Update(ctx, test.Marker("updated"))
	}
	~>(f.doorUpdate) <div>
	</div>
	
	~{
		f.doorRemoved.Update(ctx, test.Marker("removed"))
	}
	~{
		f.doorRemoved.Delete(ctx)
	}
	~(&f.doorRemoved)
	
	~{
		f.doorReplaced.Replace(ctx, test.Marker("replaced"))
	}
	
	~>(f.doorReplaced) <div>
		~(test.Marker("initReplaced"))
	</div>
}

type LifeCycleFragment struct {
	frame doors.Door
	node doors.Door
	test.NoBeam
}

elem (f *LifeCycleFragment) Main() {
	~>(f.frame) ~(f.initial())
	<button
		id="reload"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Reload(ctx)
				return false
			},
		})>
		Reload
	</button>
	<button
		id="updateEmpty"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Update(ctx, f.newEmpty())
				return false
			},
		})>
		Update1
	</button>
	<button
		id="updateContent"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Update(ctx, f.newContent())
				return false
			},
		})>
		Update2
	</button>
	<button
		id="updateEditor"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Update(ctx, f.newEditor())
				return false
			},
		})>
		Update2
	</button>
	<button
		id="clear"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Clear(ctx)
				return false
			},
		})>
		Clear
	</button>
	<button
		id="unmount"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Unmount(ctx)
				return false
			},
		})>
		Unmount
	</button>
	<button
		id="remove"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Delete(ctx)
				return false
			},
		})>
		Remove
	</button>
}

elem (f *LifeCycleFragment) initial() {
	<div>
		~>(f.node) <div>
			~(test.Marker("presist"))
		</div>
	</div>
}
elem (f *LifeCycleFragment) newEmpty() {
	<div>
		~>(f.node) <div id="new">
		</div>
	</div>
}

elem (f *LifeCycleFragment) newContent() {
	<div>
		~>(f.node) <div id="new2">
			~(test.Marker("presist2"))
		</div>
	</div>
}

elem (f *LifeCycleFragment) newEditor() {
	<div>
		~(&f.node)
	</div>
}

type FragmentDetachedReplace struct {
	report doors.Door
	frame doors.Door
	node doors.Door
	test.NoBeam
}

func (f *FragmentDetachedReplace) rep(ctx context.Context, s string) {
	f.report.Update(ctx, test.Report(s))
}

func (f *FragmentDetachedReplace) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: "+err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentDetachedReplace) mount() {
	~(&f.node)
}

elem (f *FragmentDetachedReplace) Main() {
	~{
		f.node.Update(ctx, test.Marker("replace-base"))
		f.frame.Update(ctx, f.mount())
	}
	~(&f.frame)
	~(&f.report)
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XReplace(ctx, test.Marker("replace-detached")), "ok replace")
		},
	} <button id="replace-detached">replace-detached</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XReload(ctx), "ok reload")
		},
	} <button id="reload-after-replace">reload-after-replace</button>
	~>doors.AClick{
		On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
			return f.wait(ctx, f.node.XUpdate(ctx, test.Marker("replace-updated")), "ok update")
		},
	} <button id="update-after-replace">update-after-replace</button>
	~(test.Button("remount-after-replace", func(ctx context.Context) bool {
		f.frame.Update(ctx, f.mount())
		return false
	}))
}

