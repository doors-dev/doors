type FragmentClosestXReload struct {
	frame doors.Door
	node doors.Door
	report doors.Door
	outerRenders int
	innerRenders int
	test.NoBeam
}

func (f *FragmentClosestXReload) rep(ctx context.Context, s string) {
	f.report.Inner(ctx, test.Report(s))
}

func (f *FragmentClosestXReload) wait(ctx context.Context, ch <-chan error, okMsg string) bool {
	err, ok := <-ch
	if !ok {
		f.rep(ctx, "channel closed")
		return false
	}
	if err != nil {
		f.rep(ctx, "channel err: " + err.Error())
		return false
	}
	f.rep(ctx, okMsg)
	return false
}

elem (f *FragmentClosestXReload) innerContent() {
	~{
		f.innerRenders++
	}
	<div id="x-inner-count">~(fmt.Sprintf("inner-%d", f.innerRenders))</div>
	<button
		id="xreload-nearest"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				return f.wait(ctx, doors.XReload(ctx), "ok xreload")
			},
		})>
		xreload-nearest
	</button>
}

elem (f *FragmentClosestXReload) outerContent() {
	~{
		f.outerRenders++
		f.node.Inner(ctx, f.innerContent())
	}
	<div id="x-outer-count">~(fmt.Sprintf("outer-%d", f.outerRenders))</div>
	~(&f.node)
}

elem (f *FragmentClosestXReload) Main() {
	~{
		f.frame.Inner(ctx, f.outerContent())
	}
	~(&f.frame)
	~(&f.report)
}

