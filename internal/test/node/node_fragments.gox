	node doors.Door
	test.NoBeam
}

elem (f *FragmentProxyReloadContent) mountEmpty() {
	<section id="proxy-redraw-frame">
		~>(f.node) <div id="proxy-redraw-root">
		</div>
	</section>
}

elem (f *FragmentProxyReloadContent) Main() {
	~>(f.frame) ~(f.mountEmpty())
	<button
		id="proxy-redraw-update"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Inner(ctx, test.Marker("proxy-redraw-content"))
				return false
			},
		})>
		proxy-redraw-update
	</button>
	<button
		id="proxy-redraw-remount"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.frame.Inner(ctx, f.mountEmpty())
				return false
			},
		})>
		proxy-redraw-remount
	</button>
	<button
		id="proxy-redraw-reload"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				f.node.Reload(ctx)
				return false
			},
		})>
		proxy-redraw-reload
	</button>
}

type FragmentClosestReload struct {
	frame doors.Door
	node doors.Door
	outerRenders int
	innerRenders int
	test.NoBeam
}

elem (f *FragmentClosestReload) innerContent() {
	~{
		f.innerRenders++
	}
	<div id="inner-count">~(fmt.Sprintf("inner-%d", f.innerRenders))</div>
	<button
		id="reload-nearest"
		(doors.AClick{
			On: func(ctx context.Context, _ doors.RequestEvent[doors.PointerEvent]) bool {
				doors.Reload(ctx)
				return false
			},
		})>
		reload-nearest
	</button>
}

elem (f *FragmentClosestReload) outerContent() {
	~{
		f.outerRenders++
		f.node.Inner(ctx, f.innerContent())
	}
	<div id="outer-count">~(fmt.Sprintf("outer-%d", f.outerRenders))</div>
	~(&f.node)
}

elem (f *FragmentClosestReload) Main() {
	~{
		f.frame.Inner(ctx, f.outerContent())
	}
	~(&f.frame)
}

